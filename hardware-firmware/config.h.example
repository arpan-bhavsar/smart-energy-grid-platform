// config.h.example
// 💡 LOCAL INSTRUCTIONS: If running locally, you can create a "config.h" file 
// with your credentials and include it to avoid hardcoding variables.

#ifndef CONFIG_H
#define CONFIG_H

#define WIFI_SSID "YOUR_LOCAL_WIFI_NAME"
#define WIFI_PASSWORD "YOUR_LOCAL_WIFI_PASSWORD"
#define FIREBASE_HOST "YOUR_FIREBASE_DATABASE_URL"
#define FIREBASE_AUTH "YOUR_FIREBASE_SECRET_KEY"

#endif